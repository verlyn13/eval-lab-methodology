{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-coding-evaluation-lab:evidence:1.0.0",
  "title": "Agentic-Coding Evaluation Lab Evidence Report",
  "description": "Versioned public evidence contract: report model_dump() shape, raw per-task/per-replicate outcome arrays, and reproducibility manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "core",
    "report",
    "raw_outcomes",
    "manifest"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_version",
        "core_content_hash"
      ],
      "properties": {
        "core_version": {
          "type": "string",
          "minLength": 1
        },
        "core_content_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "report": {
      "type": "object",
      "description": "The public report model_dump() shape emitted by a producer after sanitization.",
      "additionalProperties": false,
      "required": [
        "campaign_id",
        "created_at",
        "provenance",
        "statistics",
        "decision"
      ],
      "properties": {
        "campaign_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "enum": [
            "synthetic",
            "sanitized-real"
          ]
        },
        "statistics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "capability",
            "paired_delta",
            "enhanced_estimators"
          ],
          "properties": {
            "capability": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "incumbent",
                "candidate"
              ],
              "properties": {
                "incumbent": {
                  "$ref": "#/$defs/model_rate"
                },
                "candidate": {
                  "$ref": "#/$defs/model_rate"
                }
              }
            },
            "paired_delta": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "point_estimate",
                "ci",
                "bootstrap"
              ],
              "properties": {
                "point_estimate": {
                  "type": "number"
                },
                "ci": {
                  "$ref": "#/$defs/interval"
                },
                "bootstrap": {
                  "$ref": "#/$defs/bootstrap_metadata"
                }
              }
            },
            "enhanced_estimators": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "two_stage_bootstrap",
                "wilcoxon_signed_rank",
                "glmm"
              ],
              "properties": {
                "two_stage_bootstrap": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "label",
                    "estimate",
                    "ci",
                    "bootstrap"
                  ],
                  "properties": {
                    "label": {
                      "const": "enhanced:two-stage-bootstrap"
                    },
                    "estimate": {
                      "type": "number"
                    },
                    "ci": {
                      "$ref": "#/$defs/interval"
                    },
                    "bootstrap": {
                      "$ref": "#/$defs/bootstrap_metadata"
                    }
                  }
                },
                "wilcoxon_signed_rank": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "label",
                    "status"
                  ],
                  "properties": {
                    "label": {
                      "const": "enhanced:wilcoxon-signed-rank"
                    },
                    "status": {
                      "enum": [
                        "reported",
                        "not-run"
                      ]
                    },
                    "statistic": {
                      "type": [
                        "number",
                        "null"
                      ]
                    },
                    "p_value": {
                      "type": [
                        "number",
                        "null"
                      ],
                      "minimum": 0,
                      "maximum": 1
                    },
                    "n": {
                      "type": [
                        "integer",
                        "null"
                      ],
                      "minimum": 0
                    }
                  }
                },
                "glmm": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "label",
                    "status"
                  ],
                  "properties": {
                    "label": {
                      "const": "enhanced:glmm-logistic"
                    },
                    "status": {
                      "enum": [
                        "reported",
                        "not-run",
                        "optional-dependency-missing"
                      ]
                    },
                    "formula": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "backend": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "decision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rule",
            "margin",
            "promote",
            "label",
            "sign_test"
          ],
          "properties": {
            "rule": {
              "const": "bootstrap_ci_low_gt_margin"
            },
            "margin": {
              "type": "number"
            },
            "promote": {
              "type": "boolean"
            },
            "label": {
              "const": "enforcing:superiority-by-margin"
            },
            "reason": {
              "type": "string"
            },
            "sign_test": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "wins",
                "losses",
                "ties",
                "p_value",
                "alternative",
                "reported_only"
              ],
              "properties": {
                "wins": {
                  "type": "integer",
                  "minimum": 0
                },
                "losses": {
                  "type": "integer",
                  "minimum": 0
                },
                "ties": {
                  "type": "integer",
                  "minimum": 0
                },
                "p_value": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "alternative": {
                  "const": "two-sided"
                },
                "reported_only": {
                  "const": true
                }
              }
            }
          }
        }
      }
    },
    "raw_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task_outcome"
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seeds",
        "task_set",
        "models",
        "cost",
        "preflight",
        "sanitization"
      ],
      "properties": {
        "seeds": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer"
          }
        },
        "task_set": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "task_set_hash",
            "task_count",
            "replicates_per_task",
            "fixture_policy"
          ],
          "properties": {
            "task_set_hash": {
              "$ref": "#/$defs/sha256"
            },
            "task_count": {
              "type": "integer",
              "minimum": 1
            },
            "replicates_per_task": {
              "type": "integer",
              "minimum": 1
            },
            "fixture_policy": {
              "enum": [
                "synthetic",
                "sanitized-task-classes"
              ]
            },
            "task_classes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/model_manifest"
          }
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currency",
            "total",
            "basis"
          ],
          "properties": {
            "currency": {
              "type": "string",
              "minLength": 1
            },
            "total": {
              "type": "number",
              "minimum": 0
            },
            "basis": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "preflight": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "checked_at",
            "results"
          ],
          "properties": {
            "status": {
              "enum": [
                "passed",
                "failed",
                "not-run"
              ]
            },
            "checked_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "model_role",
                  "resolved"
                ],
                "properties": {
                  "model_role": {
                    "type": "string",
                    "minLength": 1
                  },
                  "resolved": {
                    "type": "boolean"
                  },
                  "model_version": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "sanitization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "checked",
            "redactions_required"
          ],
          "properties": {
            "status": {
              "enum": [
                "public-safe",
                "pending"
              ]
            },
            "checked": {
              "type": "boolean"
            },
            "redactions_required": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "low",
        "high",
        "confidence"
      ],
      "properties": {
        "low": {
          "type": [
            "number",
            "null"
          ]
        },
        "high": {
          "type": [
            "number",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "bootstrap_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "iterations",
        "alpha"
      ],
      "properties": {
        "seed": {
          "type": "integer"
        },
        "iterations": {
          "type": "integer",
          "minimum": 1
        },
        "alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      }
    },
    "model_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "successes",
        "trials",
        "rate",
        "wilson"
      ],
      "properties": {
        "successes": {
          "type": "integer",
          "minimum": 0
        },
        "trials": {
          "type": "integer",
          "minimum": 1
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "wilson": {
          "$ref": "#/$defs/interval"
        }
      }
    },
    "model_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "label",
        "version",
        "quantization"
      ],
      "properties": {
        "role": {
          "enum": [
            "incumbent",
            "candidate",
            "baseline",
            "other"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "quantization": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "task_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "task_class",
        "must_not_break",
        "replicates"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "task_class": {
          "type": "string",
          "minLength": 1
        },
        "must_not_break": {
          "type": "boolean"
        },
        "replicates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/replicate_outcome"
          }
        }
      }
    },
    "replicate_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replicate",
        "incumbent",
        "candidate"
      ],
      "properties": {
        "replicate": {
          "type": "integer",
          "minimum": 1
        },
        "incumbent": {
          "$ref": "#/$defs/run_outcome"
        },
        "candidate": {
          "$ref": "#/$defs/run_outcome"
        }
      }
    },
    "run_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "success"
      ],
      "properties": {
        "success": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "latency_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "cost": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "status": {
          "type": "string"
        }
      }
    }
  }
}
